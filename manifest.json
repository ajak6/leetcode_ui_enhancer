{
  "manifest_version": 3,
  "name": "LeetKit",
  "short_name": "LeetKit",
  "version": "1.0.0",
  "description": "A toolkit for LeetCode: inline company tags, heat highlighting, and difficulty hiding in question lists. Company tags require Premium.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LeetKit",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
